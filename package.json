{
  "name": "outrider",
  "type": "module",
  "private": true,
  "bin": {
    "outrider": "src/main.ts"
  },
  "engines": {
    "bun": ">=1.3.10"
  },
  "scripts": {
    "cli": "bun src/main.ts",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "check": "fallow",
    "fix": "fallow fix",
    "compile": "bun scripts/build.ts && rm ~/.local/bin/outrider && cp dist/outrider ~/.local/bin/outrider && outrider off && outrider on"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "oxlint-tsgolint": "^0.23.0",
    "fallow": "^2.96.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "ink": "^7.0.6",
    "react": "^19.2.7",
    "portless": "0.14.0"
  }
}
